{
  "name": "@magenta/council",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "council": "tsx src/cli.ts",
    "dashboard": "tsx src/dashboard/cli.ts --serve",
    "dashboard:no-council": "tsx src/dashboard/cli.ts --serve --no-council",
    "dashboard:build": "tsx src/dashboard/cli.ts --no-council",
    "web": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:start": "npm --prefix web run start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.0.0",
    "dotenv": "^17.4.2",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
